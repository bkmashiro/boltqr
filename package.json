{
  "name": "boltqr-bench",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "bench": "node scripts/run-bench.mjs",
    "build:extension": "vite build --config vite.extension.background.config.ts && vite build --config vite.extension.content.config.ts && vite build --config vite.extension.options.config.ts && node scripts/copy-extension-manifest.mjs && node scripts/copy-zxing-wasm.mjs && pnpm validate:extension-assets",
    "validate:extension-assets": "node scripts/validate-extension-assets.mjs",
    "icons:extension": "python3 scripts/generate-extension-icons.py",
    "test": "pnpm fixtures && vitest run",
    "fixtures": "node scripts/generate-password-page-fixtures.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.35",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.15",
    "vitest": "4.0.15"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "zxing-wasm": "^3.0.3"
  }
}
